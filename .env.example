# Optional live API credentials for local testing.
# Copy this file to .env and fill values locally. Never commit .env.
# Without any of these, the system runs fully on fixtures (the CI / static-demo default).

# --- Public data sources ---
DART_API_KEY=
KRX_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- LLM composition boundary (optional) ---
# Provider auto-detect order when ADVISOR_LIVE_LLM_PROVIDER is unset:
#   anthropic -> openai -> gemini -> openrouter (first key present wins).
# The live-LLM / ablation batches in the paper use OpenRouter.
OPENROUTER_API_KEY=
# Optional direct-provider keys (alternatives to OpenRouter):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY=          # accepted as an alias for GEMINI_API_KEY

# Force a specific provider/model at the composition boundary (else auto-detect):
ADVISOR_LIVE_LLM_PROVIDER=openrouter
ADVISOR_LIVE_LLM_MODEL=anthropic/claude-sonnet-4

# --- Eval / live-run output safety (see docs/live-run-safety.md) ---
# Redirect result writes to a scratch path so a validation run never overwrites a
# committed, manuscript-cited artifact. Leave unset for normal (intended) regen.
# ADVISOR_EVAL_OUTPUT=/tmp/harness-scratch/eval.json
# ADVISOR_FAULT_OUTPUT=/tmp/harness-scratch/fault.json
# ADVISOR_LIVE_LLM_OUTPUT=/tmp/harness-scratch/live-llm.json

# Optional UI switch for clean paper/client screenshots.
VITE_ADVISOR_DEV_UI=0
