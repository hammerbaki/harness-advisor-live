.DS_Store
.replit

# Environment and credentials
.env
.env.*
!.env.example

# Node / Vite outputs
node_modules/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local raw-source staging and heavyweight data
raw/extracted/
exports/

# Runtime traces that may contain local-only diagnostics
evals/traces/*.json
evals/results/*.progress.json
evals/results/*.progress.jsonl

# Local rerun / exploratory evaluation artifacts not cited by the paper
evals/dashboard/advisor-latency-*-30.2026-05-24.json
!evals/dashboard/advisor-latency-live-paired-baseline-30.2026-05-24.json
!evals/dashboard/advisor-latency-live-paired-optimized-30.2026-05-24.json
evals/results/*boundary-fix*.json
evals/results/*latency-baseline-30*.json
evals/results/*latency-optimized-30*.json
evals/results/*paired-baseline-rerun*.json
evals/results/*paired-optimized-rerun*.json
evals/results/*persistent-baseline*.json
evals/results/*persistent-optimized*.json
evals/results/*recheck*.json

# Nested private manuscript repo (harness-paper), if cloned here for convenience.
# This PUBLIC repo must NEVER track the manuscript. See README "Working with the
# manuscript repo". harness-paper stays a separate PRIVATE repo.
/paper/

# Generated static demo snapshots (rebuilt by npm run demo:snapshot)
public/demo/

# Local-only source materials (copyrighted issuer PDFs) — never committed.
# Redistribution governed by each source rights policy (raw/README.md).
/docs/Knowledge Base/
